{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "react-jsx",
    "jsxImportSource": "@emotion/react",
    "baseUrl": "../../..",
    "paths": {
      "jimu-*": ["jimu-*"],
      "esri/*": ["node_modules/@arcgis/core/*"],
      "react": [
        "node_modules/@types/react",
        "node_modules/.pnpm/node_modules/@types/react"
      ],
      "react/jsx-runtime": [
        "node_modules/@types/react/jsx-runtime",
        "node_modules/.pnpm/node_modules/@types/react/jsx-runtime"
      ],
      "react-dom": [
        "node_modules/@types/react-dom",
        "node_modules/.pnpm/node_modules/@types/react-dom"
      ],
      "@turf/turf": [
        "your-extensions/widgets/enhanced-measurement/node_modules/@turf/turf",
        "node_modules/.pnpm/node_modules/@turf/turf",
        "node_modules/@turf/turf"
      ],
      "jspdf": [
        "your-extensions/widgets/enhanced-measurement/node_modules/jspdf",
        "node_modules/.pnpm/node_modules/jspdf",
        "node_modules/jspdf"
      ]
    },
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true
  },
  "include": ["src"]
}
