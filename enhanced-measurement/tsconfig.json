{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2018",
    "lib": [
      "ES2018",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "react",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "moduleResolution": "Node"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "module-shims.d.ts"
  ]
}
